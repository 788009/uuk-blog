---
import ArchivePanel from "@components/ArchivePanel.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	getCategoryList,
	getSortedPostsList,
	getTagList,
} from "../utils/content-utils";

const rawPostsList = await getSortedPostsList();

// 核心修复点：使用 .map() 只提取名称字符串
const tags = (await getTagList()).map((t) => t.name);
const categories = (await getCategoryList()).map((c) => c.name);

const sortedPostsList = rawPostsList.map((post) => ({
	...post,
	data: {
		...post.data,
		category: post.data.category ?? undefined,
	},
}));
---

<MainGridLayout title={i18n(I18nKey.archive)}>
    <ArchivePanel 
        sortedPosts={sortedPostsList} 
        tags={tags} 
        categories={categories} 
        client:only="svelte"
    ></ArchivePanel>
</MainGridLayout>